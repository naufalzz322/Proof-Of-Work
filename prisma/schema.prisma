// Proof of Work Generator — Prisma Schema
// Segmen 06 · Jasa

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String @id @default(cuid())
  slug         String @unique
  name         String
  contactName  String
  contactTitle String?
  contactPhone String
  contactEmail String?
  address      String
  logoUrl      String?
  jobs              Job[]
  recurringSchedules RecurringSchedule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Worker {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  phone        String
  role         WorkerRole   @default(FIELD)
  sessions     WorkSession[]
  checklistItems ChecklistItem[]
  photos       AreaPhoto[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum WorkerRole {
  FIELD
  SUPERVISOR
  ADMIN
}

model Job {
  id              String        @id @default(cuid())
  slug            String        @unique
  jobNumber       String        @unique
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  title           String
  description     String?
  locationAddress String
  locationLat     Decimal
  locationLng     Decimal
  locationRadius  Int           @default(200)
  scheduledDate   DateTime
  scheduledTime   String
  status          JobStatus     @default(DRAFT)
  notes           String?
  areas           JobArea[]
  workers         WorkSession[]
  signature       ClientSignature?
  report          JobReport?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([scheduledDate])
  @@index([status])
}

enum JobStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  INVOICED
}

model JobArea {
  id        String          @id @default(cuid())
  jobId     String
  job       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int             @default(0)
  items     ChecklistItem[]
  photos    AreaPhoto[]
  createdAt DateTime        @default(now())

  @@index([jobId])
}

model ChecklistItem {
  id      String   @id @default(cuid())
  areaId  String
  area    JobArea  @relation(fields: [areaId], references: [id], onDelete: Cascade)
  label   String
  isDone  Boolean  @default(false)
  doneAt  DateTime?
  doneBy  String?  // workerId
  worker  Worker?  @relation(fields: [doneBy], references: [id])

  @@index([areaId])
}

model AreaPhoto {
  id         String    @id @default(cuid())
  areaId     String
  area       JobArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  type       PhotoType
  url        String
  takenAt    DateTime
  uploadedBy String    // workerId
  worker     Worker    @relation(fields: [uploadedBy], references: [id])

  @@index([areaId])
}

enum PhotoType {
  BEFORE
  AFTER
}

model WorkSession {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId           String
  worker             Worker   @relation(fields: [workerId], references: [id])
  checkInAt          DateTime?
  checkInLat         Decimal?
  checkInLng         Decimal?
  checkInNote        String?
  isOverrideLocation Boolean  @default(false)
  isLate             Boolean  @default(false)
  lateMinutes        Int      @default(0)
  checkOutAt         DateTime?
  createdAt          DateTime @default(now())

  @@unique([jobId, workerId])
  @@index([jobId])
}

model ClientSignature {
  id            String   @id @default(cuid())
  jobId         String   @unique
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  signatureUrl  String
  signerName    String
  signerTitle   String
  signedAt      DateTime
  isPendingSign Boolean  @default(false)
  pendingReason String?
  createdAt     DateTime @default(now())
}

model JobReport {
  id          String    @id @default(cuid())
  jobId       String    @unique
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  pdfUrl      String
  generatedAt DateTime  @default(now())
  sentAt      DateTime?
  sentToEmail String?
}

// ========================================
// JOB TEMPLATES — Reusable job structures
// ========================================

model JobTemplate {
  id          String          @id @default(cuid())
  name        String          // Template name (e.g., "Kantor Standard", "Hotel Room")
  description String?         // Description of when to use this template
  areas       JobTemplateArea[]
  createdBy   String?         // Worker who created (admin)
  createdAt  DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([name])
}

model JobTemplateArea {
  id          String              @id @default(cuid())
  templateId  String
  template    JobTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String              // Area name (e.g., "Lobby", "Toilet")
  sortOrder   Int                @default(0)
  items       JobTemplateItem[]

  @@index([templateId])
}

model JobTemplateItem {
  id         String              @id @default(cuid())
  areaId     String
  area       JobTemplateArea     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  label      String              // Checklist item label
  sortOrder  Int                @default(0)

  @@index([areaId])
}

// ========================================
// RECURRING SCHEDULE — Automated job generation
// ========================================

model RecurringSchedule {
  id            String      @id @default(cuid())
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  title         String      // Job title template (e.g., "Pembersihan Rutin {date}")
  locationAddress String
  locationLat   Decimal     @default(0)
  locationLng   Decimal     @default(0)
  locationRadius Int        @default(200)
  scheduledTime String      // Time of day (HH:MM)
  recurrence    RecurrenceType
  // For specific days: 0=Sun, 1=Mon, ..., 6=Sat
  daysOfWeek    Int[]       @default([]) // e.g., [1,3,5] for Mon,Wed,Fri
  // For monthly: day of month (1-31)
  dayOfMonth    Int?        // e.g., 15 for 15th of each month
  // End date (optional)
  endDate       DateTime?
  isActive      Boolean     @default(true)
  lastGenerated DateTime?   // Last time jobs were auto-generated
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([clientId])
  @@index([isActive])
}

enum RecurrenceType {
  DAILY       // Every day
  WEEKLY       // Specific days of week
  MONTHLY      // Specific day of month
}

// ========================================
// ADMIN NOTIFICATIONS — Job event notifications
// ========================================

model AdminNotification {
  id        String      @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  jobId     String?     // Related job if applicable
  jobSlug   String?     // Cached slug for linking
  jobNumber String?      // Cached for display
  seenBy    String[]     @default([]) // Array of user IDs who have seen this notification
  sentVia   NotificationChannel[]
  createdAt DateTime    @default(now())

  @@index([createdAt])
}

enum NotificationType {
  WORKER_CHECKIN      // Worker checked in
  JOB_ASSIGNED        // Workers assigned to job
  JOB_COMPLETED        // Job marked as completed
  CLIENT_SIGNED        // Client signed
  JOB_OVERDUE         // Job past scheduled time, not checked in
  REPORT_SENT          // PDF report sent to client
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  IN_APP
}
